PORT=8080
SESSION_JWT_SECRET=replace_with_a_long_random_secret
PRIMARY_AI_PROVIDER=openai
FALLBACK_AI_PROVIDER=gemini

# Google OAuth (backend-side)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# AI provider keys used by backend (users no longer need to provide their own)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: return canned responses without calling provider APIs
MOCK_AI=false
